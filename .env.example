COMPOSE_PROJECT_NAME=supermario

DOMAIN=supermario.o-r.kr
LETSENCRYPT_EMAIL=replace-with-your-email@example.com
LETSENCRYPT_STAGING=false
NGINX_MODE=https

FRONTEND_BLUE_IMAGE=ghcr.io/supermario-flood-monitoring/supermario-react:prod
FRONTEND_GREEN_IMAGE=ghcr.io/supermario-flood-monitoring/supermario-react:prod
BACKEND_BLUE_IMAGE=ghcr.io/supermario-flood-monitoring/supermario-django:prod
BACKEND_GREEN_IMAGE=ghcr.io/supermario-flood-monitoring/supermario-django:prod
LLM_BLUE_IMAGE=ghcr.io/supermario-flood-monitoring/supermario-llm:prod
LLM_GREEN_IMAGE=ghcr.io/supermario-flood-monitoring/supermario-llm:prod

DATABASE_ENGINE=postgres
POSTGRES_DB=supermario
POSTGRES_USER=supermario
POSTGRES_PASSWORD=change-this-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DJANGO_SECRET_KEY=change-this-secret-key
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=supermario.o-r.kr,59.9.136.144,192.168.0.101,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://supermario.o-r.kr,http://supermario.o-r.kr,http://59.9.136.144,http://192.168.0.101
SUPERMARIO_JWT_SECRET_KEY=change-this-jwt-secret-key
SUPERMARIO_REFRESH_COOKIE_SAMESITE=Lax
SUPERMARIO_REFRESH_COOKIE_SECURE=true
SUPERMARIO_PUBLIC_BASE_URL=https://supermario.o-r.kr
SUPERMARIO_API_BASE_URL=https://supermario.o-r.kr/api
SUPERMARIO_LLM_BASE_URL=https://supermario.o-r.kr/llm
SUPERMARIO_LLM_ANALYZE_URL=https://supermario.o-r.kr/llm/analyze

REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

STOP_OLD_AFTER_DEPLOY=false
MAX_HEALTH_RETRIES=30
HEALTH_RETRY_SECONDS=2

